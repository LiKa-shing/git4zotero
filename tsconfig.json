{
  "extends": "zotero-types/entries/sandbox",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2022"
  },
  "include": [
    "bootstrap.js",
    "chrome/content/preferences.mjs",
    "chrome/content/src/**/*.mjs"
  ]
}
